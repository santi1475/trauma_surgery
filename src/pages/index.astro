---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header'
import Hero from '../components/Hero'
import IngenieriaSinLimites from '../components/IngenieriaSinLimites'
import Soluciones from '../components/Soluciones'
import InfoCards from '../components/InfoCards'
import ProductosSection from '../components/ProductosSection'
import DiagonalGalleryBanner from '../components/DiagonalGalleryBanner'
import GlobalStats from '../components/GlobalStats'
import InstagramFeed from '../components/InstagramFeed'
import Contacto from '../components/Contacto'
import GlobalPresence from '../components/GlobalPresence'
import Footer from '../components/Footer'
---
<Layout>
  <Header client:only="react" />
  <main class="block m-0 p-0">
    <!-- S1: Hero slider interactivo (above the fold) -->
    <Hero client:only="react" />
    <!-- S2: Ingeniería Sin Límites (sin WebGL — hidrata al ser visible) -->
    <IngenieriaSinLimites client:visible />
    <!-- S3: Visor 3D interactivo (canvas R3F, defer hasta visible) -->
    <ProductosSection client:visible />
    <!-- S4: Soluciones destacadas -->
    <Soluciones client:visible />
    <!-- S5: Banner Diagonal Gallery -->
    <DiagonalGalleryBanner client:visible />
    <!-- S6: Diferenciales -->
    <InfoCards client:visible />
    <!-- S7: Global Stats -->
    <GlobalStats client:visible />
    <!-- S8: Instagram Feed -->
    <InstagramFeed client:visible />
    <!-- Contacto -->
    <Contacto client:visible />
    <!-- Presencia Global (teaser mapa) -->
    <GlobalPresence client:visible />
  </main>
  <Footer client:visible />
</Layout>
